# Server port
PORT=3000

# PostgreSQL connection string
# Example: postgresql://user:password@localhost:5432/ecommerce_db
DATABASE_URL=

# Session/JWT secret (optional, has a default fallback)
SESSION_SECRET=change-me-to-something-secret

# Log level: trace | debug | info | warn | error (optional, defaults to 'info')
LOG_LEVEL=info
